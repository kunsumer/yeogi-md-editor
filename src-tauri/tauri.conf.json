{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Yeogi .MD Editor",
  "version": "0.2.0",
  "identifier": "com.yeogi.mdeditor",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Yeogi .MD Editor",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset: http://asset.localhost; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost ws://localhost:1420 http://localhost:1420"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mdown", "mkd"],
        "name": "Markdown",
        "description": "Markdown document",
        "role": "Editor",
        "mimeType": "text/markdown"
      }
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJDQzBGNzdCQTY2RTQ2RDIKUldUU1JtNm1lL2ZBTEhQekt1VGVxbXFGdC9ER0lGTXA3WFp2Y2lZYm0vWUN2REVJZFpvaFpyUGsK",
      "endpoints": [
        "https://github.com/kunsumer/yeogi-md-editor/releases/latest/download/latest.json"
      ]
    }
  }
}
