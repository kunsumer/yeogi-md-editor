{
  "name": "yeogi-md-editor",
  "private": true,
  "version": "0.3.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "tsc --noEmit",
    "release:keygen": "echo '\\nGenerating Tauri updater signing keypair.\\nStore the private key securely — losing it orphans all existing installs.\\n' && tauri signer generate -w ~/.tauri/yeogi-update.key && echo '\\n→ Copy the printed PUBLIC key into src-tauri/tauri.conf.json -> plugins.updater.pubkey'",
    "release:apple-keygen": "bash scripts/create-apple-signing-cert.sh",
    "release:build": "bash scripts/release-build.sh",
    "release:steps": "echo '\\nYeogi .MD Editor release checklist\\n===================================\\n\\n1. Bump version in lockstep:\\n     package.json                     .version\\n     src-tauri/Cargo.toml            version\\n     src-tauri/tauri.conf.json       .version\\n\\n2. Load signing env (first time: pnpm release:keygen)\\n     export TAURI_SIGNING_PRIVATE_KEY=\"$(cat ~/.tauri/yeogi-update.key)\"\\n     export TAURI_SIGNING_PRIVATE_KEY_PASSWORD=\"<passphrase>\"\\n\\n3. Build the universal bundle:\\n     pnpm release:build\\n\\n4. Publish a GitHub release tagged v<version>. Upload:\\n     - *.dmg\\n     - *.app.tar.gz\\n     - *.app.tar.gz.sig\\n     - latest.json  (see docs/releasing.md for template)\\n\\nFull walkthrough:  docs/releasing.md\\n'"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.41.1",
    "@shikijs/rehype": "^4.0.2",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@tiptap/core": "^3.22.4",
    "@tiptap/extension-code-block-lowlight": "^3.22.4",
    "@tiptap/extension-highlight": "^3.22.4",
    "@tiptap/extension-image": "^3.22.4",
    "@tiptap/extension-link": "^3.22.4",
    "@tiptap/extension-subscript": "^3.22.4",
    "@tiptap/extension-superscript": "^3.22.4",
    "@tiptap/extension-table": "^3.22.4",
    "@tiptap/extension-table-cell": "^3.22.4",
    "@tiptap/extension-table-header": "^3.22.4",
    "@tiptap/extension-table-row": "^3.22.4",
    "@tiptap/extension-task-item": "^3.22.4",
    "@tiptap/extension-task-list": "^3.22.4",
    "@tiptap/extension-text-align": "^3.22.4",
    "@tiptap/extension-underline": "^3.22.4",
    "@tiptap/pm": "^3.22.4",
    "@tiptap/react": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "codemirror": "^6.0.2",
    "dompurify": "^3.4.0",
    "katex": "^0.16.45",
    "lowlight": "^3.3.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-mark": "^4.0.0",
    "markdown-it-sub": "^2.0.0",
    "markdown-it-sup": "^2.0.0",
    "markdown-it-task-lists": "^2.1.1",
    "mermaid": "^11.14.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "shiki": "^4.0.2",
    "tiptap-markdown": "^0.9.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.2.0",
    "@types/hast": "^3.0.4",
    "@types/markdown-it-footnote": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/ui": "^4.1.4",
    "jsdom": "^29.0.2",
    "playwright": "^1.59.1",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.4"
  }
}
